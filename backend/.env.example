# Copy to backend/.env and fill in. Never commit the real .env.
# Sign up at https://railradar.in -> create an API key -> pick a tier
# (free tier to start; paid from ~Rs 1,000/mo for 20k requests).
RAILRADAR_API_KEY=your_key_here

# Optional overrides:
# RAILRADAR_BASE_URL=https://api.railradar.in
# RAILRADAR_TIMEOUT=8
